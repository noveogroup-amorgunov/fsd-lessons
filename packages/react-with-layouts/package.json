{
  "name": "react-with-layouts",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "depcruise": "depcruise src --include-only '^src' --output-type dot | dot -T svg > dependency-graph.svg",
    "depcruise:full": "FULL_GRAPH=true depcruise src --include-only '^src' --output-type dot | dot -T svg > dependency-graph.full.svg"
  },
  "dependencies": {
    "@monorepo/react-core": "workspace:*",
    "@radix-ui/react-slot": "^1.2.0",
    "@tailwindcss/vite": "^4.1.4",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.4",
    "wouter": "^3.7.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.14.1",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "dependency-cruiser": "^16.10.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.0.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.4.1"
  }
}
