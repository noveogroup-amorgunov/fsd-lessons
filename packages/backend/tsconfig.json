{
  "compilerOptions": {
    "target": "es2016",
    "baseUrl": ".",
    "rootDir": "./src",
    "module": "commonjs",
    "paths": {
      "~/*": ["src/*"]
    },
    "strict": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "generated/**/*"],
  "exclude": ["node_modules"]
}
